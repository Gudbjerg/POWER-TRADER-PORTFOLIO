# Streamlit Community Cloud secrets template
# Rename this file to secrets.toml and fill in your keys,
# OR add these keys directly in the Streamlit Cloud dashboard under Settings → Secrets.
#
# Do NOT commit secrets.toml to git — it is in .gitignore.

AGSI_API_KEY = "your_gie_api_key_here"
ENTSOE_API_KEY = "your_entsoe_api_key_here"
